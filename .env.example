# Flask
FLASK_APP=app:create_app
FLASK_ENV=development

# 安全密钥（生产环境务必更换为随机字符串）
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# 数据库（MySQL）
DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/mijia
TEST_DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/mijia_test

# go2rtc 摄像头流服务
GO2RTC_URL=http://127.0.0.1:1984
# go2rtc 配置：复制 go2rtc.yaml.example 为 go2rtc.yaml，填入实际的小米账号和设备信息
# cp go2rtc.yaml.example go2rtc.yaml

# HomeKit 桥接（可选，需要 pip install -e ".[homekit]"）
HOMEKIT_ENABLED=false
HOMEKIT_PORT=51826
HOMEKIT_PIN=123-45-678

# HomeKit 自动登录（二选一：直接设置 MIJIA_TOKEN 或设置用户名密码自动获取）
# MIJIA_TOKEN=your-jwt-access-token
# MIJIA_USERNAME=your-username
# MIJIA_PASSWORD=your-password
